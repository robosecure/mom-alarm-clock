{
  "name": "mom-alarm-clock-functions",
  "description": "Cloud Functions + Firestore rules tests for Mom Alarm Clock",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions",
    "test": "firebase emulators:exec --only firestore 'npx jest --forceExit'",
    "test:rules": "firebase emulators:exec --only firestore 'npx jest rules.test.js --forceExit'"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "jest": "^29.0.0"
  }
}